# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub!

# OKX API Credentials (if using OKX)
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_BASE_URL=https://www.okx.com

# Binance API Credentials (for data fetching)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_SYMBOL=ETHUSDT

# Roostoo API Credentials (if using Roostoo)
ROOSTOO_API_KEY=your_roostoo_api_key_here
ROOSTOO_SECRET_KEY=your_roostoo_secret_key_here
ROOSTOO_BASE_URL=https://mock-api.roostoo.com
ROOSTOO_PAIR=ETH/USD
ROOSTOO_BASE_CURRENCY=USD

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Other Settings
EXCHANGE_TYPE=ROOSTOO
BINANCE_SYMBOL=ETHUSDT
